# Public URL for self-hosted Jitsi (set DNS A record to your server IP first)
PUBLIC_URL=https://meet.kannarimusicacademy.com

# Basic deployment toggles (TLS is terminated at main nginx)
ENABLE_LETSENCRYPT=0
ENABLE_HTTP_REDIRECT=0
DISABLE_HTTPS=1
ENABLE_XMPP_WEBSOCKET=1
ENABLE_AUTH=0
ENABLE_GUESTS=1
AUTH_TYPE=internal
TZ=UTC

# XMPP domains
XMPP_DOMAIN=meet.kannarimusicacademy.com
XMPP_AUTH_DOMAIN=auth.meet.kannarimusicacademy.com
XMPP_MUC_DOMAIN=muc.meet.kannarimusicacademy.com
XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.kannarimusicacademy.com
XMPP_GUEST_DOMAIN=guest.meet.kannarimusicacademy.com
XMPP_RECORDER_DOMAIN=recorder.meet.kannarimusicacademy.com

# Component users
JICOFO_AUTH_USER=focus
JVB_AUTH_USER=jvb
JIBRI_XMPP_USER=jibri
JIBRI_RECORDER_USER=recorder

# Component passwords/secrets
JICOFO_COMPONENT_SECRET=4P3jXh8mQ2sV9yK6nD7aR1tB5uW0cL
JICOFO_AUTH_PASSWORD=5f7eK9m2Qp4R8t1Vw3Yx6Za0Bc2De
JVB_AUTH_PASSWORD=7hJ2kL9mN5pQ3rT6vW1xY4zA8bC0dE
