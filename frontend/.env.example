# Frontend Environment Variables - Copy this to .env.local and fill in your values

# API Configuration
REACT_APP_API_URL=http://127.0.0.1:8000/api
REACT_APP_SITE_URL=http://127.0.0.1:8000

# Stripe Configuration
# Get your Stripe keys from: https://dashboard.stripe.com/apikeys
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Production Configuration (uncomment when deploying)
# REACT_APP_API_URL=https://your-backend-url.com/api
# REACT_APP_SITE_URL=https://your-backend-url.com/
# REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_live_your_production_key_here
